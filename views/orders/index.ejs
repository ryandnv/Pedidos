<%- include("../partials/head", { pageTitle: "Pedidos" }) %>
<%- include("../partials/navbar") %>

<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Pedidos</h2>
    <a href="/order/new" class="btn btn-primary">Novo pedido</a>
  </div>

  <div class="card shadow-sm p-3">
    <div class="table-responsive">
      <table class="table table-striped align-middle">
        <thead>
          <tr>
            <th>Número do pedido</th>
            <th>Valor</th>
            <th>Data</th>
            <th>Itens</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (orders.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center">Nenhum pedido cadastrado.</td>
            </tr>
          <% } %>

          <% orders.forEach(order => { %>
            <tr>
              <td><strong><%= order.orderId %></strong></td>
              <td>R$ <%= order.value %></td>
              <td><%= new Date(order.creationDate).toLocaleString("pt-BR") %></td>
              <td>
                <% if(order.items && order.items.length > 0) { %>
                  <%= order.items.length %> item(ns)
                <% } else { %>
                  0
                <% } %>
              </td>
              <td>
                <a href="/order/show/<%= order.orderId %>" class="btn btn-outline-secondary btn-sm">Ver</a>
                <a href="/order/edit/<%= order.orderId %>" class="btn btn-outline-primary btn-sm">Editar</a>

                <form action="/order/delete/<%= order.orderId %>" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-outline-danger btn-sm">Excluir</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include("../partials/footer") %>