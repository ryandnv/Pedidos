<%- include("../partials/head", { pageTitle: "Novo Pedido" }) %>
<%- include("../partials/navbar") %>

<div class="container" style="max-width: 800px;">
  <div class="card shadow-sm p-4">
    <h2 class="fw-bold mb-4">Novo pedido</h2>

    <form action="/order/save" method="POST">
      <div class="mb-3">
        <label class="form-label">Número do pedido</label>
        <input type="text" name="orderId" class="form-control" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Valor total</label>
        <input type="number" name="value" step="0.01" class="form-control" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Data de criação</label>
        <input type="datetime-local" name="creationDate" class="form-control" required>
      </div>

      <hr>

      <h5 class="fw-bold mb-3">Item do pedido</h5>

      <div class="mb-3">
        <label class="form-label">ID do produto</label>
        <input type="number" name="productId" class="form-control" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Quantidade</label>
        <input type="number" name="quantity" class="form-control" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Preço</label>
        <input type="number" name="price" step="0.01" class="form-control" required>
      </div>

      <button type="submit" class="btn btn-primary w-100">Salvar pedido</button>
    </form>
  </div>
</div>

<%- include("../partials/footer") %>